<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="br.com.douglas.brittosstoffvendas.ui.login.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@+id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="br.com.douglas.brittosstoffvendas.ui.login.HomeFragment"
        android:label="Home"/>

    <fragment
        android:id="@+id/pedidosFragment"
        android:name="br.com.douglas.brittosstoffvendas.ui.login.PedidosFragment"
        android:label="Pedidos"/>

    <fragment
        android:id="@+id/catalogoFragment"
        android:name="br.com.douglas.brittosstoffvendas.ui.login.CatalogoFragment"
        android:label="Catalogo"/>

    <fragment
        android:id="@+id/perfilFragment"
        android:name="br.com.douglas.brittosstoffvendas.ui.login.PerfilFragment"
        android:label="Perfil"/>

</navigation>