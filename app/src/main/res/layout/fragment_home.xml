<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/grey">

    <!-- ====== HEADER AZUL ====== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Textos de saudacao -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_saudacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ola, Douglas"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bem-vindo de volta"
                android:textSize="13sp"
                android:textColor="#B3C5F7"/>
        </LinearLayout>

        <!-- Icone de notificacao -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_sino"
            app:tint="@color/white"
            android:layout_marginEnd="16dp"/>

        <!-- Avatar circular com iniciais -->
        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_avatar"
            android:text="JS"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- ====== CONTEUDO SCROLLAVEL ====== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- RESUMO DO DIA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESUMO DO DIA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/blue"
                android:layout_marginBottom="12dp"/>

            <!-- Cards deslizaveis horizontalmente -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Card 1: Pedidos Abertos -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_carrinho"
                                app:tint="@color/blue"
                                android:layout_marginBottom="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pedidos Abertos"
                                android:textSize="12sp"
                                android:textColor="@color/darkGrey"/>
                            <TextView
                                android:id="@+id/tv_pedidos_abertos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/blue"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 2: Vendido Hoje -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_dinheiro"
                                app:tint="@color/green"
                                android:layout_marginBottom="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vendido Hoje"
                                android:textSize="12sp"
                                android:textColor="@color/darkGrey"/>
                            <TextView
                                android:id="@+id/tv_vendido_hoje"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R$ 4.500"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/blue"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 3: Entregas -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="130dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_caminhao"
                                app:tint="@color/red"
                                android:layout_marginBottom="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Entregas"
                                android:textSize="12sp"
                                android:textColor="@color/darkGrey"/>
                            <TextView
                                android:id="@+id/tv_entregas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/red"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- NOVA VENDA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nova Venda"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/blue"
                android:layout_marginBottom="16dp"/>

            <!-- Botoes Nova Reforma e Nova Fabricacao -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_nova_reforma"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Nova Reforma"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/blue"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_sofa"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_nova_fabricacao"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Nova Fabricacao"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/red"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_fabricacao"/>
            </LinearLayout>

            <!-- Botao Ver Modelos -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ver_modelos"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Ver Modelos de Sofas"
                android:textColor="@color/blue"
                app:strokeColor="@color/blue"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_catalogo"
                app:iconTint="@color/blue"
                android:layout_marginBottom="24dp"/>

            <!-- PEDIDOS EM PRODUCAO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pedidos em Producao"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue"/>

                <TextView
                    android:id="@+id/tv_ver_todos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VER TODOS"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/red"/>
            </LinearLayout>

            <!-- Lista de pedidos -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_pedidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
